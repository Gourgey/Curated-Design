---
layout: layouts/base.njk
eleventyComputed:
  title: "{{ site.home.title }}"
  description: "{{ site.home.metaDescription or site.settings.description }}"
bodyClass: min-h-screen text-[#f2f2f2] font-inter
topLogo: white_logo_no_text_on_transparent.svg
showBackground: true
preloadImage: /assets/images/projects/16-9_images/monet-living.webp
---
<main class="page-main">
    {% set logoFile = "white_small_logo_and_large_text_on_transparent.svg" %}
    {% include "partials/hero-brand.njk" %}

    <section class="hero">
        <div class="container hero-inner hero-inner--center">
            <h1 class="headline">{{ site.home.hero.headline }}</h1>
            <p class="subhead mx-auto">{{ site.home.hero.subhead }}</p>
        </div>
    </section>

    <nav id="pills" class="pillmenu-wrap" aria-label="Quick filters">
        <button
            id="pillsToggle"
            class="pillmenu-toggle pills-toggle"
            type="button"
            aria-expanded="false"
            aria-controls="pillsPanel"
        >
            <span class="pills-toggle-label">Menu</span>
        </button>

        <ul class="pillmenu pills-desktop">
            <li><a class="pill active" href="#portfolio">Featured Projects</a></li>
            <li><a class="pill" href="#services">Curated Services</a></li>
            <li><a class="pill" href="#selected-work">Collections</a></li>
            <li><a class="pill" href="#about">Design Philosophy</a></li>
        </ul>

        <div id="pillsPanel" class="pills-panel" hidden>
            <a class="pill" href="#portfolio">Featured Projects</a>
            <a class="pill" href="#services">Curated Services</a>
            <a class="pill" href="#selected-work">Collections</a>
            <a class="pill" href="#about">Design Philosophy</a>
        </div>
    </nav>

    <section
        id="portfolio"
        class="dock-panel narrow"
        data-theme="dark"
        aria-label="Portfolio carousel"
    >
        <div class="carousel">
            <button class="ctrl prev" id="prev" aria-label="Previous">‹</button>

            <div class="viewport">
                <div class="viewport-clip">
                    <div class="track" id="track">
                        {% for slide in site.home.carousel.slides %}
                        {% set slideProject = [slide] | resolveEntries(collections.publishedProject, "project") | first %}
                        {% set slideSrc = slide.image or slideProject.data.heroImage %}
                        {% set slideAlt = slide.alt or slideProject.data.heroAlt or slideProject.data.title %}
                        {% if slideSrc %}
                        <div class="slide" aria-label="{{ loop.index }} of {{ site.home.carousel.slides.length }}">
                            <img
                                src="{{ slideSrc }}"
                                alt="{{ slideAlt }}"
                                width="1600"
                                height="900"
                                loading="{% if loop.first %}eager{% else %}lazy{% endif %}"
                                {% if loop.first %}fetchpriority="high"{% endif %}
                                decoding="async"
                                draggable="false"
                            />
                        </div>
                        {% endif %}
                        {% endfor %}
                    </div>
                </div>
            </div>

            <button class="ctrl next" id="next" aria-label="Next">›</button>
        </div>

        <div id="dots" class="dots" aria-label="Slide indicators"></div>
    </section>

    <section id="services" class="section band-1" data-theme="dark">
        <div class="container">
            <span class="kicker">{{ site.home.servicesSection.kicker }}</span>
            <h2 class="h2">{{ site.home.servicesSection.heading }}</h2>
            <p class="lead">{{ site.home.servicesSection.lead }}</p>

            {% set featuredServices = site.home.servicesSection.featuredServices | resolveEntries(collections.publishedService, "service") %}
            <div class="card-grid">
                {% for service in featuredServices %}
                <a
                    class="card {{ service | homeCardSpan(featuredServices.length) }}"
                    href="/curated_services/{{ service.data.slug }}.html"
                    aria-label="View {{ service.data.title }} service"
                >
                    <div class="img-wrap">
                        {% if service.data.cardImage %}
                        <img
                            src="{{ service.data.cardImage }}"
                            alt="{{ service.data.cardAlt or service.data.title }}"
                            loading="lazy"
                            decoding="async"
                        />
                        {% endif %}
                    </div>
                    <div class="body">
                        <h3 class="title">{{ service.data.title }}</h3>
                        {% if service.data.summary %}<p class="muted">{{ service.data.summary }}</p>{% endif %}
                    </div>
                </a>
                {% endfor %}
            </div>
        </div>
    </section>

    <section id="selected-work" class="section band-2" data-theme="light">
        <div class="container">
            <span class="kicker2">{{ site.home.collectionsSection.kicker }}</span>
            <h2 class="h22">{{ site.home.collectionsSection.heading }}</h2>

            {% set featuredProjects = site.home.collectionsSection.featuredProjects | resolveEntries(collections.publishedProject, "project") %}
            <div class="card-grid">
                {% for project in featuredProjects %}
                {% set projectCardSrc = project.relation.image or project.data.cardImage %}
                <a class="card {{ project | homeCardSpan(featuredProjects.length) }}" href="/projects/{{ project.data.slug }}.html">
                    <div class="img-wrap">
                        {% image projectCardSrc, project.data.cardAlt or project.data.title, "(min-width: 1024px) 33vw, (min-width: 700px) 50vw, 100vw", "lazy", null, "card" %}
                    </div>
                    <div class="body">
                        <h3 class="title2">{{ project.data.title }}</h3>
                        {% if project.data.kicker %}<p class="muted2">{{ project.data.kicker }}</p>{% endif %}
                    </div>
                </a>
                {% endfor %}
            </div>

            <a class="button" href="/projects.html">
                <span class="dot" aria-hidden="true"></span>
                All projects
            </a>
        </div>
    </section>

    <section id="about" class="section band-3" data-theme="dark">
        <div class="container">
            <span class="kicker">{{ site.home.philosophy.kicker }}</span>

            <div class="split">
                <div class="media">
                    {% image site.home.philosophy.image, site.home.philosophy.imageAlt, "(min-width: 900px) 52vw, 100vw", "lazy" %}
                </div>
                <div class="content">
                    <h2 class="h2">{{ site.home.philosophy.heading }}</h2>
                    {% for paragraph in site.home.philosophy.paragraphs %}
                    <p>{{ paragraph }}</p>
                    {% endfor %}
                </div>
            </div>

            <div class="cta" style="margin-top: 36px">
                <h3 class="h2" style="margin: 0">{{ site.home.cta.heading }}</h3>
                <p class="lead" style="margin: 0 0 8px">{{ site.home.cta.text }}</p>
                <a class="button" href="mailto:{{ site.settings.email }}">
                    <span class="dot" aria-hidden="true"></span>
                    {{ site.home.cta.buttonLabel }}
                </a>
            </div>
        </div>
    </section>
</main>
