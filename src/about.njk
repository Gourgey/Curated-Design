---
layout: layouts/base.njk
eleventyComputed:
  title: "{{ site.about.title }}"
  description: "{{ site.about.metaDescription or site.settings.description }}"
permalink: studio/index.html
htmlClass: about-page
bodyClass: about-page min-h-screen font-inter
---
{% set romans = ["i", "ii", "iii", "iv", "v", "vi", "vii", "viii", "ix", "x"] %}
<main id="main-content" class="studio" tabindex="-1">
    {% include "partials/hero-brand.njk" %}

    <header class="studio-header">
        {% if site.about.eyebrow %}
        <p class="studio-header__eyebrow">{{ site.about.eyebrow }}</p>
        {% endif %}
        <div>
            <h1 class="studio-header__title">{{ site.about.introHeading | safe }}</h1>
            <p class="studio-header__intro">{{ site.about.introText }}</p>
            <a class="header-more-link" href="/services/">View all services</a>
        </div>
    </header>

    {% if site.about.founder %}
    <section class="studio-founder">
        {% if site.about.founder.eyebrow %}
        <p class="studio-founder__eyebrow">{{ site.about.founder.eyebrow }}</p>
        {% endif %}
        <div class="studio-founder__body">
            {% if site.about.founder.heading %}
            <h2 class="studio-founder__heading">{{ site.about.founder.heading }}</h2>
            {% endif %}
            {% for paragraph in site.about.founder.paragraphs %}
            <p>{{ paragraph }}</p>
            {% endfor %}
        </div>
    </section>
    {% endif %}

    <section class="studio-two">
        <div>
            <h2 class="studio-two__heading">{{ site.about.workHeading }}</h2>
            <div class="studio-two__body">
                {% for paragraph in site.about.workParagraphs %}
                <p>{{ paragraph }}</p>
                {% endfor %}
            </div>
        </div>
        <div>
            <h2 class="studio-two__heading">{{ site.about.focusHeading }}</h2>
            <ul class="studio-two__list">
                {% for area in site.about.focusAreas %}
                <li>{{ area }}</li>
                {% endfor %}
            </ul>
        </div>
    </section>

    {% if site.about.process or site.about.processSteps %}
    <section class="studio-process">
        {% if site.about.process %}
        <div class="studio-process__lead">
            {% if site.about.process.eyebrow %}
            <p class="studio-process__eyebrow">{{ site.about.process.eyebrow }}</p>
            {% endif %}
            {% if site.about.process.title %}
            <h2 class="studio-process__title">{{ site.about.process.title | safe }}</h2>
            {% endif %}
        </div>
        {% endif %}

        <div class="studio-process__grid">
            {% for step in site.about.processSteps %}
            <article class="step">
                <p class="step__roman">{{ romans[loop.index0] }}</p>
                {% if step.label %}<p class="step__label">{{ step.label }}</p>{% endif %}
                {% if step.head %}<h3 class="step__head">{{ step.head }}</h3>{% endif %}
                {% if step.text %}<p class="step__body">{{ step.text }}</p>{% endif %}
            </article>
            {% endfor %}
        </div>

        {% if site.about.processNote %}
        <p class="studio-process__note">{{ site.about.processNote }}</p>
        {% endif %}
    </section>
    {% endif %}

    <section class="studio-locations">
        {% if site.about.locationsEyebrow %}
        <p class="studio-locations__eyebrow">{{ site.about.locationsEyebrow }}</p>
        {% endif %}
        <div class="studio-locations__body">
            <h2 class="studio-locations__heading">{{ site.about.locationsHeading }}</h2>
            <p>{{ site.about.locationsText }}</p>
        </div>
    </section>

</main>
