<!doctype html>
<html lang="en"{% if htmlClass %} class="{{ htmlClass }}"{% endif %}>
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1" />
        <title>{{ title }}</title>
        {# `description` is composed via eleventyComputed (already HTML-escaped once);
           `| safe` prevents a second escape pass that would produce `&amp;#39;` etc. #}
        {% set metaDescription = description or site.settings.description %}
        {% if metaDescription %}
        <meta name="description" content="{{ metaDescription | safe }}" />
        {% endif %}
        {% set shouldNoindex = noindex or (project and project.data.status != "published") %}
        {% if shouldNoindex %}
        <meta name="robots" content="noindex, follow" />
        {% endif %}

        {# Favicons — generated from the Curated Design brand mark; served from
           site root via the `public/` passthrough copy. #}
        <link rel="icon" href="/favicon.ico" sizes="any" />
        <link rel="icon" type="image/png" sizes="48x48" href="/favicon-48x48.png" />
        <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />

        {# Canonical + Open Graph + Twitter — site-wide defaults overridable per-page #}
        {% set siteUrl = site.settings.siteUrl %}
        {% set canonicalUrl = (siteUrl + page.url) if siteUrl and page.url else "" %}
        {% set ogImageRaw = ogImage or (project.data.heroImage if project) or (service.data.coverImage if service) or site.settings.shareImage %}
        {% set ogImage = (siteUrl + ogImageRaw) if siteUrl and ogImageRaw and ogImageRaw[0] == "/" else ogImageRaw %}
        {% set ogImageAlt = ogImageAlt or (project.data.heroAlt if project) or (service.data.coverAlt if service) or site.settings.shareImageAlt %}
        {% set ogType = ogType or ("article" if (project or service) else "website") %}
        {% if canonicalUrl %}
        <link rel="canonical" href="{{ canonicalUrl }}" />
        {% endif %}
        <meta property="og:site_name" content="{{ site.settings.studioName }}" />
        <meta property="og:type" content="{{ ogType }}" />
        <meta property="og:title" content="{{ title }}" />
        {% if metaDescription %}<meta property="og:description" content="{{ metaDescription | safe }}" />{% endif %}
        {% if canonicalUrl %}<meta property="og:url" content="{{ canonicalUrl }}" />{% endif %}
        {% if ogImage %}<meta property="og:image" content="{{ ogImage }}" />{% endif %}
        {% if ogImage and ogImageAlt %}<meta property="og:image:alt" content="{{ ogImageAlt }}" />{% endif %}
        <meta name="twitter:card" content="{{ "summary_large_image" if ogImage else "summary" }}" />
        <meta name="twitter:title" content="{{ title }}" />
        {% if metaDescription %}<meta name="twitter:description" content="{{ metaDescription | safe }}" />{% endif %}
        {% if ogImage %}<meta name="twitter:image" content="{{ ogImage }}" />{% endif %}
        {% if ogImage and ogImageAlt %}<meta name="twitter:image:alt" content="{{ ogImageAlt }}" />{% endif %}

        {# Self-hosted fonts (P5.1) -- @font-face rules live in
           assets/css-partials/01-tokens.css. Preload only the two files
           used above the fold on every template (Inter body copy, the
           Cormorant Garamond display heading); the italic file loads
           on demand where it's actually used. #}
        <link rel="preload" href="/assets/fonts/inter-variable.woff2" as="font" type="font/woff2" crossorigin />
        <link rel="preload" href="/assets/fonts/cormorant-garamond-variable.woff2" as="font" type="font/woff2" crossorigin />
        <link rel="stylesheet" href="/assets/css/styles.css?v={{ site.cssVersion }}" />

        {# Organization/logo structured data — homepage only, so Google can
           associate the brand logo with the business. Logo URL is absolute. #}
        {% if page.url == "/" %}
        <script type="application/ld+json">
        {
            "@context": "https://schema.org",
            "@type": "Organization",
            "name": "Curated Design",
            "alternateName": "{{ site.settings.studioName }}",
            "url": "{{ site.settings.siteUrl }}/",
            "logo": "{{ site.settings.siteUrl }}/images/curated-design-logo.png"
        }
        </script>
        {% endif %}
    </head>

    <body class="{{ bodyClass }}">
        <a class="skip-link" href="#main-content">Skip to main content</a>
        <div id="top"></div>

        {% if showBackground %}
        <div id="bg" aria-hidden="true">
            <picture>
                <source
                    type="image/avif"
                    srcset="
                        /assets/images/background-640.avif 640w,
                        /assets/images/background-1280.avif 1280w,
                        /assets/images/background-1920.avif 1920w,
                        /assets/images/background-2560.avif 2560w
                    "
                    sizes="100vw"
                />
                <source
                    type="image/webp"
                    srcset="
                        /assets/images/background-640.webp 640w,
                        /assets/images/background-1280.webp 1280w,
                        /assets/images/background-1920.webp 1920w,
                        /assets/images/background-2560.webp 2560w
                    "
                    sizes="100vw"
                />
                <img
                    id="bgImg"
                    src="/assets/images/background-1920.webp"
                    alt=""
                    decoding="async"
                    fetchpriority="high"
                />
            </picture>

            <div class="bg-dim"></div>
        </div>
        {% endif %}

        <header id="siteHeader">
            <a href="/{% if sectionTop %}#top{% endif %}" id="topLogo" class="top-left-logo">
                <img
                    src="/assets/images/logos/{{ topLogo | default('logo_no_text_on_transparent.svg') }}"
                    alt="{{ site.settings.studioName }}"
                />
            </a>

            {% include "partials/nav.njk" %}
        </header>

        {{ content | safe }}

        {% include "partials/footer.njk" %}

        {% set defaultScripts = ['/assets/js/navigation.js', '/assets/js/carousels.js', '/assets/js/scroll-effects.js'] %}
        {% for script in scripts | default(defaultScripts) %}
        <script src="{{ script }}" defer></script>
        {% endfor %}
    </body>
</html>
