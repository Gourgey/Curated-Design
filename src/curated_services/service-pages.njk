---
pagination:
  data: collections.publishedService
  size: 1
  alias: service
permalink: "curated_services/{{ service.data.slug }}.html"
layout: layouts/base.njk
eleventyComputed:
  title: "{{ service.data.metaTitle or service.data.title }} – Curated Design Studio"
  description: "{{ service.data.metaDescription or service.data.summary or service.data.intro or site.settings.description }}"
htmlClass: concept-page
bodyClass: concept-page font-inter
scripts:
  - /assets/js/main.js
  - /assets/js/contact-form.js
---
{% set hasGlance = service.data.glance and service.data.glance.length %}
{% set hasSections = service.data.sections and service.data.sections.length %}
{% set coverAlt = service.data.coverAlt or service.data.title %}

<main id="main-content" class="service" tabindex="-1">
    <header class="service-header">
        <p class="service-header__eyebrow">{{ service.data.eyebrow or "Service" }}</p>
        <div>
            <h1 class="service-header__title">{{ service.data.title | safe }}</h1>
            {% if service.data.intro %}
            <p class="service-header__intro">{{ service.data.intro }}</p>
            {% endif %}
        </div>
    </header>

    {% if service.data.coverImage %}
    <figure class="service-hero" aria-label="{{ service.data.title }} hero image">
        {% image service.data.coverImage, coverAlt, "100vw", "eager" %}
    </figure>
    {% endif %}

    <section class="service-body">
        <div class="service-body__main">
            {% if hasSections %}
            {% for section in service.data.sections %}
            {% if section.heading or (section.items and section.items.length) %}
            <section class="service-section">
                {% if section.heading %}
                <h2 class="service-section__heading label-small">{{ section.heading }}</h2>
                {% endif %}
                {% if section.items and section.items.length %}
                <{{ section.listType | default('ul') }} class="service-section__list">
                    {% for item in section.items %}
                    {% if item %}<li>{{ item }}</li>{% endif %}
                    {% endfor %}
                </{{ section.listType | default('ul') }}>
                {% endif %}
                {% if section.note %}
                <p class="service-section__note">{{ section.note }}</p>
                {% endif %}
            </section>
            {% endif %}
            {% endfor %}
            {% endif %}
        </div>

        <aside class="service-body__aside" aria-label="Service details">
            {% if hasGlance %}
            <div class="service-glance">
                <h2 class="label-small">At a glance</h2>
                <dl class="service-glance__list">
                    {% for item in service.data.glance %}
                    {% if item.label or item.text %}
                    <div class="service-glance__row">
                        {% if item.label %}<dt class="service-glance__label">{{ item.label }}</dt>{% endif %}
                        {% if item.text %}<dd class="service-glance__value">{{ item.text }}</dd>{% endif %}
                    </div>
                    {% endif %}
                    {% endfor %}
                </dl>
            </div>
            {% endif %}

            <div class="service-enquiry">
                {% if service.data.enquiryHeading %}
                <h2 class="service-enquiry__title">{{ service.data.enquiryHeading }}</h2>
                {% endif %}
                {% if service.data.enquiryText %}
                <p class="service-enquiry__intro">{{ service.data.enquiryText }}</p>
                {% endif %}

                <form
                    class="service-enquiry__form"
                    name="service-enquiry"
                    method="POST"
                    action="/thank-you/"
                    netlify
                    data-netlify="true"
                    data-netlify-honeypot="bot-field"
                    data-enhanced-netlify-form
                    data-success-target="serviceFormSuccess"
                >
                    <input type="hidden" name="form-name" value="service-enquiry" />
                    <input type="hidden" name="service" value="{{ service.data.title }}" />

                    <p class="hidden">
                        <label>
                            Don’t fill this out if you're human:
                            <input name="bot-field" />
                        </label>
                    </p>

                    <div class="field">
                        <label class="field__label" for="{{ service.data.slug }}-name">Name</label>
                        <input class="field__input" type="text" id="{{ service.data.slug }}-name" name="name" autocomplete="name" placeholder="Your full name" required />
                    </div>

                    <div class="field">
                        <label class="field__label" for="{{ service.data.slug }}-email">Email</label>
                        <input class="field__input" type="email" id="{{ service.data.slug }}-email" name="email" autocomplete="email" placeholder="you@studio.com" required />
                    </div>

                    <div class="field">
                        <label class="field__label" for="{{ service.data.slug }}-location">Location</label>
                        <input class="field__input" type="text" id="{{ service.data.slug }}-location" name="location" placeholder="e.g. London / Glasgow / Remote" />
                    </div>

                    <div class="field">
                        <label class="field__label" for="{{ service.data.slug }}-scope">Scope</label>
                        <input class="field__input" type="text" id="{{ service.data.slug }}-scope" name="scope" placeholder="e.g. entrance hall / 1 bedroom / restaurant concept" required />
                    </div>

                    <div class="field field--optional">
                        <label class="field__label" for="{{ service.data.slug }}-budget">Budget</label>
                        <input class="field__input" type="text" id="{{ service.data.slug }}-budget" name="budget" placeholder="e.g. £5k–£15k" />
                    </div>

                    <div class="field">
                        <label class="field__label" for="{{ service.data.slug }}-message">Notes</label>
                        <textarea class="field__textarea" id="{{ service.data.slug }}-message" name="message" rows="4" placeholder="Timeline, constraints, budget range, what you’re hoping to change…" required></textarea>
                    </div>

                    <p class="service-enquiry__error hidden" role="alert" data-form-error tabindex="-1">
                        We couldn’t send your enquiry. Please try again.
                    </p>

                    <p class="service-enquiry__privacy">
                        We’ll use your details only to respond to your enquiry.
                        <a href="/privacy-notice.html">Read our privacy notice.</a>
                    </p>

                    <div class="service-enquiry__submit-row">
                        <button type="submit" class="service-enquiry__submit" data-form-submit>
                            <span data-form-submit-label>Send enquiry</span>
                            <span class="service-enquiry__arrow" aria-hidden="true">→</span>
                        </button>
                    </div>
                </form>

                <div id="serviceFormSuccess" class="service-enquiry__success hidden" role="status" aria-live="polite" data-form-success tabindex="-1">
                    <h2 class="service-enquiry__success-title">Enquiry sent</h2>
                    <p class="service-enquiry__success-text">Thanks for getting in touch — we’ll respond shortly.</p>
                </div>
            </div>
        </aside>
    </section>

</main>

{% if service.data.ctaHeading or service.data.ctaText %}
{% set heading = service.data.ctaHeading %}
{% set text = service.data.ctaText %}
{% set href = "/contact.html" %}
{% set ctaClass = "about-cta-band section" %}
{% set ctaContainerClass = "container" %}
{% set ctaStyle = "text-align: center" %}
{% set label = "Contact the studio" %}
{% include "partials/cta-band.njk" %}
{% endif %}
