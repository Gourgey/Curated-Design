{% macro pill(href, label) -%}
<p class="backlink-row"><a class="backlink backlink--pill" href="{{ href }}">{{ label }}</a></p>
{%- endmacro %}

{% macro hero(href, label) -%}
<a class="backlink backlink--hero" href="{{ href }}"><span aria-hidden="true">← </span>{{ label }}</a>
{%- endmacro %}

{% macro breadcrumb(items) -%}
<nav class="breadcrumb" aria-label="Breadcrumb">
    <ol class="breadcrumb__list">
        {% for item in items %}
        <li class="breadcrumb__item">{% if item.href %}<a class="breadcrumb__link" href="{{ item.href }}">{{ item.label }}</a>{% else %}<span aria-current="page">{{ item.label }}</span>{% endif %}</li>
        {% endfor %}
    </ol>
</nav>
{%- endmacro %}
