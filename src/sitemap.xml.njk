---
permalink: sitemap.xml
eleventyExcludeFromCollections: true
---
<?xml version="1.0" encoding="UTF-8"?>
<urlset xmlns="http://www.sitemaps.org/schemas/sitemap/0.9">
{%- set base = site.settings.siteUrl -%}
{%- for url in ['/', '/projects.html', '/about.html', '/contact.html', '/apps/'] %}
<url><loc>{{ base }}{{ url }}</loc></url>
{%- endfor %}
{%- for app in apps.items %}
<url><loc>{{ base }}/apps/{{ app.slug }}/</loc></url>
{%- for kind in app.supportPages %}
<url><loc>{{ base }}/apps/{{ app.slug }}/{{ kind }}/</loc></url>
{%- endfor %}
{%- endfor %}
{%- for service in collections.publishedService | sortByOrder %}
<url><loc>{{ base }}/curated_services/{{ service.data.slug }}.html</loc></url>
{%- endfor %}
{%- for project in collections.publishedProject | sortByOrder %}
<url><loc>{{ base }}/projects/{{ project.data.slug }}.html</loc></url>
{%- endfor %}
</urlset>
