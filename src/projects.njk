---
layout: layouts/base.njk
title: Projects – Curated Design Studio
eleventyComputed:
  description: "{{ site.projectsPage.metaDescription or site.settings.description }}"
permalink: projects.html
bodyClass: projects-page font-inter
topLogo: white_logo_no_text_on_transparent.svg
---
<main class="page-main">
    {% include "partials/hero-brand.njk" %}

    <section class="hero">
        <div class="container hero-inner hero-inner--center">
            <h1 class="headline">{{ site.projectsPage.heroHeadline }}</h1>
            <p class="subhead mx-auto">{{ site.projectsPage.heroSubhead }}</p>
        </div>
    </section>

    {% set listedProjects = collections.publishedProject | sortByOrder | where("showInProjects", true) %}
    {% set visibleCategories = site.projectsPage.categories | groupByCategory(listedProjects) %}

    <nav id="pills" class="pillmenu-wrap" aria-label="Project categories">
        <button
            id="pillsToggle"
            class="pillmenu-toggle pills-toggle"
            type="button"
            aria-expanded="false"
            aria-controls="pillsPanel"
        >
            <span class="pills-toggle-label">Menu</span>
        </button>

        <ul class="pillmenu pills-desktop">
            {% for entry in visibleCategories %}
            <li><a class="pill{% if loop.first %} active{% endif %}" href="#{{ entry.category.id }}">{{ entry.category.label }}</a></li>
            {% endfor %}
        </ul>

        <div id="pillsPanel" class="pills-panel" hidden>
            {% for entry in visibleCategories %}
            <a class="pill" href="#{{ entry.category.id }}">{{ entry.category.label }}</a>
            {% endfor %}
        </div>
    </nav>

    <section class="projects-band">
        {% for entry in visibleCategories %}
        {% set category = entry.category %}
        <section id="{{ category.id }}" class="{% if loop.first %}section-pad{% else %}py-14{% endif %}">
            <div class="projects-wrap">
                <div class="widget-area">
                    {% if category.label %}<span class="section-label">{{ category.label }}</span>{% endif %}

                    <div class="section-head">
                        {% if category.heading %}<h2 class="h2">{{ category.heading }}</h2>{% endif %}
                        {% if category.note %}<p class="section-note">{{ category.note }}</p>{% endif %}
                    </div>

                    <div class="widget-grid">
                        {% for project in entry.projects %}
                        <a class="widget {{ project.data | projectGridClass }}" href="/projects/{{ project.data.slug }}.html">
                            <img
                                src="{{ project.data.cardImage }}"
                                alt="{{ project.data.cardAlt or project.data.title }}"
                                loading="lazy"
                                decoding="async"
                                class="widget-media"
                            />
                            <div class="widget-body">
                                <p class="widget-title">{{ project.data.title }}</p>
                                {% if project.data.kicker %}<p class="widget-meta">{{ project.data.kicker }}</p>{% endif %}
                            </div>
                        </a>
                        {% endfor %}
                    </div>
                </div>
            </div>
        </section>
        {% endfor %}
    </section>

    {% set heading = site.settings.ctaHeading %}
    {% set text = site.settings.ctaText %}
    {% set href = "mailto:" + site.settings.email %}
    {% set label = site.settings.primaryCtaText %}
    {% include "partials/cta-band.njk" %}
</main>
