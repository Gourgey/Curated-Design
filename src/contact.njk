---
layout: layouts/base.njk
eleventyComputed:
  title: "{{ site.contact.title }}"
  description: "{{ site.contact.metaDescription or site.settings.description }}"
permalink: contact.html
htmlClass: contact-page
bodyClass: contact-page min-h-screen font-inter
scripts:
  - /assets/js/main.js
  - /assets/js/contact-form.js
---
<main id="main-content" class="page-main" tabindex="-1">
    {% include "partials/hero-brand.njk" %}

    <div class="contact-body">
        <section class="contact-intro">
            <h1 class="contact-headline">{{ site.contact.heading | safe }}</h1>
            <p class="contact-subline">{{ site.contact.lead }}</p>

            <address class="studio-meta">
                <p class="studio-meta__name">{{ site.settings.studioName }}</p>
                <p class="studio-meta__addr">{{ site.settings.location }}</p>
                <a class="studio-meta__email" href="mailto:{{ site.settings.email }}">{{ site.settings.email }}</a>
                {% if site.contact.note %}
                <p class="studio-meta__note">{{ site.contact.note }}</p>
                {% endif %}
            </address>
        </section>

        <div class="contact-form-col">
            <form
                id="contactForm"
                class="contact-form"
                name="contact"
                method="POST"
                action="/thank-you/"
                netlify
                data-netlify="true"
                data-netlify-honeypot="bot-field"
                data-enhanced-netlify-form
                data-success-target="contactFormSuccess"
            >
                <input type="hidden" name="form-name" value="contact" />

                <p class="hidden">
                    <label>
                        Don’t fill this out if you're human:
                        <input name="bot-field" />
                    </label>
                </p>

                <div class="field">
                    <label class="field__label" for="name">Name</label>
                    <input class="field__input" type="text" id="name" name="name" autocomplete="name" placeholder="Your full name" required />
                </div>

                <div class="field">
                    <label class="field__label" for="email">Email</label>
                    <input class="field__input" type="email" id="email" name="email" autocomplete="email" placeholder="you@studio.com" required />
                </div>

                <div class="field">
                    <label class="field__label" for="project-type">Project type</label>
                    <select class="field__select" id="project-type" name="project-type">
                        <option value="" disabled selected>Select an option</option>
                        <option value="residential">Residential home / apartment</option>
                        <option value="hospitality">Hospitality (restaurant, bar, hotel)</option>
                        <option value="workspace">Workspace / commercial</option>
                        <option value="other">Other</option>
                    </select>
                </div>

                <div class="field field--optional">
                    <label class="field__label" for="budget">Approximate budget</label>
                    <input class="field__input" type="text" id="budget" name="budget" placeholder="e.g. £80,000 – £150,000" />
                </div>

                <div class="field">
                    <label class="field__label" for="message">Project outline</label>
                    <textarea class="field__textarea" id="message" name="message" rows="4" placeholder="Location, scope, timings, and anything else you’d like to share." required></textarea>
                </div>

                <p id="contactFormError" class="contact-form-error hidden" role="alert" data-form-error tabindex="-1">
                    We couldn’t send your message. Please try again.
                </p>

                <p class="contact-form-privacy">
                    We’ll use your details only to respond to your enquiry.
                    <a href="/privacy-notice.html">Read our privacy notice.</a>
                </p>

                <div class="contact-submit-row">
                    <button id="contactFormSubmit" type="submit" class="contact-submit" data-form-submit>
                        <span id="contactFormSubmitLabel" data-form-submit-label>{{ site.contact.submitLabel or "Send enquiry" }}</span>
                        <span class="contact-submit__arrow" aria-hidden="true">→</span>
                    </button>
                    {% if site.contact.submitMeta %}
                    <span class="contact-submit-meta">{{ site.contact.submitMeta }}</span>
                    {% endif %}
                </div>
            </form>

            <div id="contactFormSuccess" class="contact-form-success hidden" role="status" aria-live="polite" data-form-success tabindex="-1">
                <h2 class="contact-form-success__title">Form submitted</h2>
                <p class="contact-form-success__text">Thanks for reaching out — we’ll respond shortly.</p>
            </div>
        </div>
    </div>
</main>
