---
layout: layouts/base.njk
eleventyComputed:
  title: "{{ site.home.title }}"
  description: "{{ site.home.metaDescription or site.settings.description }}"
bodyClass: min-h-screen text-[#f2f2f2] font-inter
topLogo: white_logo_no_text_on_transparent.svg
showBackground: true
---
<main id="main-content" class="page-main" tabindex="-1">
    {% set logoFile = "white_small_logo_and_large_text_on_transparent.svg" %}
    {% include "partials/hero-brand.njk" %}

    <section class="hero">
        <div class="container hero-inner hero-inner--center">
            <h1 class="home-hero__title">{{ site.home.hero.headline | safe }}</h1>
            <p class="home-hero__intro">{{ site.home.hero.subhead }}</p>
        </div>
    </section>

    <nav id="pills" class="pillmenu-wrap" aria-label="Quick filters">
        <button
            id="pillsToggle"
            class="pillmenu-toggle pills-toggle"
            type="button"
            aria-expanded="false"
            aria-controls="pillsPanel"
        >
            <span class="pills-toggle-label">Menu</span>
        </button>

        <ul class="pillmenu pills-desktop">
            <li><a class="pill active" href="#portfolio">Featured Projects</a></li>
            <li><a class="pill" href="#services">Curated Services</a></li>
            <li><a class="pill" href="#selected-work">Collections</a></li>
            <li><a class="pill" href="#about">Design Philosophy</a></li>
        </ul>

        <div id="pillsPanel" class="pills-panel" hidden>
            <a class="pill" href="#portfolio">Featured Projects</a>
            <a class="pill" href="#services">Curated Services</a>
            <a class="pill" href="#selected-work">Collections</a>
            <a class="pill" href="#about">Design Philosophy</a>
        </div>
    </nav>

    <section
        id="portfolio"
        class="dock-panel narrow"
        data-theme="dark"
        aria-label="Featured work"
    >
        {% set carousel = site.home.carousel.slides | carouselSlides(collections.publishedProject) %}
        <div class="carousel{% if carousel.length == 1 %} carousel--single{% endif %}"{% if carousel.length > 1 %} role="region" aria-roledescription="carousel" aria-label="Featured projects" tabindex="0"{% endif %}>
            {% if carousel.length > 1 %}
            <button class="ctrl prev" id="prev" type="button" aria-label="Previous featured project">‹</button>
            {% endif %}

            <div class="viewport">
                <div class="viewport-clip">
                    <div class="track" id="track">
                        {% for slide in carousel %}
                        <article class="slide" role="group"{% if carousel.length > 1 %} aria-roledescription="slide" aria-label="{{ loop.index }} of {{ carousel.length }}"{% endif %}{% if loop.first %} aria-current="true"{% endif %}>
                            <a class="featured-project" href="{{ slide.url }}">
                                {% image slide.src, slide.alt, "(min-width: 1040px) 1000px, calc(100vw - 40px)", ("eager" if loop.first else "lazy") %}
                                <span class="featured-project__overlay">
                                    <span class="featured-project__kicker">{{ slide.kicker }}</span>
                                    {% if slide.statusLabel %}<span class="featured-project__status">{{ slide.statusLabel }}</span>{% endif %}
                                    <span class="featured-project__title">{{ slide.title }}</span>
                                    <span class="featured-project__action">View project <span aria-hidden="true">→</span></span>
                                </span>
                            </a>
                        </article>
                        {% endfor %}
                    </div>
                </div>
            </div>

            {% if carousel.length > 1 %}
            <button class="ctrl next" id="next" type="button" aria-label="Next featured project">›</button>
            {% endif %}
        </div>

        {% if carousel.length > 1 %}
        <div id="dots" class="dots" role="group" aria-label="Choose featured project"></div>
        {% endif %}
    </section>

    <section id="services" class="home-section home-services" data-theme="dark">
        <div class="home-section__inner">
            <div class="home-section__head">
                <p class="home-section__eyebrow">{{ site.home.servicesSection.kicker }}</p>
                <div>
                    <h2 class="home-section__title">{{ site.home.servicesSection.heading | safe }}</h2>
                    {% if site.home.servicesSection.lead %}
                    <p class="home-section__intro">{{ site.home.servicesSection.lead }}</p>
                    {% endif %}
                </div>
            </div>

            {% set featuredServices = site.home.servicesSection.featuredServices | resolveEntries(collections.publishedService, "service") %}
            <div class="home-services__grid">
                {% for service in featuredServices %}
                <a class="card card--service" href="/curated_services/{{ service.data.slug }}.html">
                    <div class="card__media">
                        {% image service.data.cardImage, service.data.cardAlt or service.data.title, "(min-width: 1280px) 400px, (min-width: 761px) 33vw, 100vw", "lazy", "", "card" %}
                    </div>
                    <h3 class="card__title">{{ service.data.title }}</h3>
                    {% if service.data.summary %}
                    <p class="card__summary">{{ service.data.summary }}</p>
                    {% endif %}
                </a>
                {% endfor %}
            </div>
        </div>
    </section>

    <section id="selected-work" class="home-section home-collections" data-theme="light">
        <div class="home-section__inner">
            <div class="home-section__head">
                <p class="home-section__eyebrow">{{ site.home.collectionsSection.kicker }}</p>
                <div>
                    <h2 class="home-section__title">{{ site.home.collectionsSection.heading | safe }}</h2>
                    {% if site.home.collectionsSection.lead %}
                    <p class="home-section__intro">{{ site.home.collectionsSection.lead }}</p>
                    {% endif %}
                </div>
            </div>

            {% set featuredProjects = site.home.collectionsSection.featuredProjects | resolveEntries(collections.publishedProject, "project") %}
            <div class="home-collections__grid{% if featuredProjects.length == 1 %} home-collections__grid--single{% endif %}">
                {% for project in featuredProjects %}
                {% set projectCardSrc = project.relation.image or project.data.cardImage %}
                <a class="home-project" href="/projects/{{ project.data.slug }}.html">
                    <div class="home-project__media">
                        {% image projectCardSrc, project.data.cardAlt or project.data.title, "(min-width: 1280px) 400px, (min-width: 761px) 33vw, 100vw", "lazy", "", "card" %}
                    </div>
                    <h3 class="home-project__title">{{ project.data.title }}</h3>
                    {% if project.data.kicker %}
                    <p class="home-project__kicker">{{ project.data.kicker }}</p>
                    {% endif %}
                </a>
                {% endfor %}
            </div>

            {% if site.home.collectionsSection.moreLink %}
            <div class="home-collections__more">
                {% if site.home.collectionsSection.moreLabel %}
                <p class="home-collections__more-label">{{ site.home.collectionsSection.moreLabel }}</p>
                {% endif %}
                <a class="home-collections__more-link" href="{{ site.home.collectionsSection.moreHref or '/projects.html' }}">{{ site.home.collectionsSection.moreLink }}</a>
            </div>
            {% endif %}
        </div>
    </section>

    <section id="about" class="home-philosophy" data-theme="dark">
        <div class="home-philosophy__inner">
            <figure class="home-philosophy__media">
                {% image site.home.philosophy.image, site.home.philosophy.imageAlt, "(min-width: 1280px) 600px, (min-width: 761px) 50vw, 100vw", "lazy" %}
            </figure>
            <div class="home-philosophy__body">
                <p class="home-philosophy__eyebrow">{{ site.home.philosophy.kicker }}</p>
                <h2 class="home-philosophy__title">{{ site.home.philosophy.heading | safe }}</h2>
                {% for paragraph in site.home.philosophy.paragraphs %}
                <p class="home-philosophy__text">{{ paragraph }}</p>
                {% endfor %}
            </div>
        </div>
    </section>

    <section class="home-cta" data-theme="dark" aria-label="Contact call to action">
        <div class="home-cta__inner">
            {% if site.home.cta.kicker %}
            <p class="home-cta__eyebrow">{{ site.home.cta.kicker }}</p>
            {% endif %}
            <h2 class="home-cta__title">{{ site.home.cta.heading | safe }}</h2>
            {% if site.home.cta.text %}
            <p class="home-cta__subline">{{ site.home.cta.text }}</p>
            {% endif %}
            <a class="home-cta__link" href="{{ site.settings.primaryCtaUrl or ('mailto:' + site.settings.email) }}">
                <span class="home-cta__dot" aria-hidden="true"></span>
                {{ site.home.cta.buttonLabel }}
            </a>
        </div>
    </section>
</main>
