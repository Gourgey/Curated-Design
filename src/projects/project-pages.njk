---
pagination:
  data: collections.publishedProject
  size: 1
  alias: project
permalink: "projects/{{ project.data.slug }}.html"
layout: layouts/base.njk
eleventyComputed:
  title: "{{ project.data.title }} – Curated Design Studio"
htmlClass: project-page
bodyClass: project-page font-inter
sectionTop: true
---
{% set isComingSoon = project.data.status == "coming_soon" %}
<main class="page-main">
    <div class="project-topbar">
        <a class="project-backlink" href="/projects.html">← Back to Work</a>
    </div>

    <header class="project-hero" aria-label="Project hero">
        {% set hasHeroCarousel = (not isComingSoon) and project.data.gallery and project.data.gallery.images and project.data.gallery.images.length %}
        <figure class="project-hero-media{% if hasHeroCarousel %} project-hero-carousel{% endif %}"{% if hasHeroCarousel %} data-project-carousel{% endif %}>
            <div class="project-hero-track"{% if hasHeroCarousel %} data-project-carousel-track{% endif %}>
                <div class="project-hero-slide">
                    <img
                        src="{{ project.data.heroImage }}"
                        alt="{{ project.data.heroAlt }}"
                        loading="eager"
                        decoding="async"
                    />
                </div>
                {% if hasHeroCarousel %}
                {% for item in project.data.gallery.images %}
                <div class="project-hero-slide">
                    <img src="{{ item.image }}" alt="{{ item.alt }}" loading="lazy" decoding="async" />
                </div>
                {% endfor %}
                {% endif %}
            </div>
            {% if hasHeroCarousel %}
            <button class="project-hero-control project-hero-control--prev" type="button" data-project-carousel-prev aria-label="Previous project image">‹</button>
            <button class="project-hero-control project-hero-control--next" type="button" data-project-carousel-next aria-label="Next project image">›</button>
            <div class="project-hero-dots" data-project-carousel-dots aria-label="Project image slide indicators"></div>
            {% endif %}
        </figure>

        <div class="project-hero-overlay">
            <div class="project-hero-inner">
                <p class="project-kicker">{{ project.data.kicker }}</p>

                <h1 class="project-title">
                    <span>{{ project.data.title }}</span>
                    {% if isComingSoon %}
                    <span class="coming-soon-badge" aria-label="Status">{{ project.data.statusLabel | default("Coming soon", true) }}</span>
                    {% endif %}
                </h1>

                <p class="project-subtitle">{{ project.data.subtitle }}</p>

                <div class="project-tags" aria-label="Project tags">
                    {% for tag in project.data.projectTags %}
                    <span class="project-tag">{{ tag }}</span>
                    {% endfor %}
                </div>
            </div>
        </div>
    </header>

    {% if isComingSoon %}
    <section class="section project-body">
        <div class="container project-wrap">
            <div class="project-grid">
                <article class="project-article project-prose">
                    <h2 class="project-h2">{{ project.data.articleHeading | default(project.data.statusLabel) | default("Coming soon") }}</h2>

                    <p class="project-lead">{{ project.data.lead | default(project.data.summary) | default(project.data.subtitle) }}</p>

                    {% if project.data.callout and (project.data.callout.title or project.data.callout.text) %}
                    <div class="project-callout">
                        {% if project.data.callout.title %}
                        <p class="project-callout-title">{{ project.data.callout.title }}</p>
                        {% endif %}
                        {% if project.data.callout.text %}
                        <p class="project-callout-text">{{ project.data.callout.text }}</p>
                        {% endif %}
                    </div>
                    {% endif %}
                </article>

                <aside class="project-aside" aria-label="Project facts">
                    <div class="project-facts">
                        <h2 class="project-facts-title">Project facts</h2>

                        {% if project.data.facts and project.data.facts.length %}
                        <dl class="project-facts-list">
                            {% for fact in project.data.facts %}
                            <div class="project-fact">
                                <dt>{{ fact.label }}</dt>
                                <dd>{{ fact.value }}</dd>
                            </div>
                            {% endfor %}
                        </dl>

                        <div class="project-facts-divider"></div>
                        {% endif %}

                        {% if project.data.asideText %}
                        <p class="project-p project-muted">{{ project.data.asideText }}</p>
                        {% endif %}

                        <a href="/contact.html" class="button button-full">
                            <span class="dot" aria-hidden="true"></span>
                            Enquire
                        </a>
                    </div>
                </aside>
            </div>
        </div>
    </section>
    {% else %}
    <section class="section project-body">
        <div class="container project-wrap">
            <div class="project-grid">
                <article class="project-article project-prose">
                    <h2 class="project-h2">{{ project.data.articleHeading | default("Overview") }}</h2>

                    <p class="project-lead">{{ project.data.lead }}</p>

                    {% if project.data.body %}
                    {{ project.data.body | markdownify | safe }}
                    {% endif %}

                    {% if project.data.callout %}
                    <div class="project-callout">
                        <p class="project-callout-title">{{ project.data.callout.title }}</p>
                        <p class="project-callout-text">{{ project.data.callout.text }}</p>
                    </div>
                    {% endif %}

                    {% for section in project.data.extraSections %}
                    {% if section.heading %}
                    <h2 class="project-h2">{{ section.heading }}</h2>
                    {% endif %}
                    {% if section.text %}
                    {{ section.text | markdownify | safe }}
                    {% endif %}
                    {% endfor %}
                </article>

                <aside class="project-aside" aria-label="Project facts">
                    <div class="project-facts">
                        <h2 class="project-facts-title">Project facts</h2>

                        <dl class="project-facts-list">
                            {% for fact in project.data.facts %}
                            <div class="project-fact">
                                <dt>{{ fact.label }}</dt>
                                <dd>{{ fact.value }}</dd>
                            </div>
                            {% endfor %}
                        </dl>

                        <div class="project-facts-divider"></div>

                        <p class="project-p project-muted">{{ project.data.asideText }}</p>

                        <a href="/contact.html" class="button button-full">
                            <span class="dot" aria-hidden="true"></span>
                            Enquire
                        </a>
                    </div>
                </aside>
            </div>
        </div>
    </section>
    {% endif %}

    {% set heading = project.data.ctaHeading %}
    {% set text = project.data.ctaText %}
    {% set href = "/contact.html" %}
    {% set ctaClass = "about-cta-band section" %}
    {% set ctaContainerClass = "container" %}
    {% set ctaStyle = "text-align: center" %}
    {% set label = "Contact the studio" %}
    {% include "partials/cta-band.njk" %}
</main>
