<section id="{{ ctaId | default('enquiry') }}" class="{{ ctaClass | default('about-cta-band') }}">
    <div class="{{ ctaContainerClass | default('cta-band__inner') }}">
        <h2 class="h2">{{ heading }}</h2>
        <p class="lead mx-auto about-cta-lead">{{ text }}</p>

        <a href="{{ href | default('/contact/') }}" class="button about-cta-button">
            <span class="dot" aria-hidden="true"></span>
            {{ label | default('Contact the studio') }}
        </a>
    </div>
</section>
