<nav
    id="floatingNavPill"
    class="nav-pill nav-pill--right"
    aria-label="Primary navigation"
>
    <button
        class="pillmenu-toggle"
        type="button"
        aria-label="Open primary menu"
        aria-expanded="false"
        aria-controls="floatingPillMenu"
    >
        <span class="burger-line"></span>
        <span class="burger-line"></span>
        <span class="burger-line"></span>
    </button>

    <ul id="floatingPillMenu" class="pillmenu">
        <li class="overlay-home-only">
            <a class="pill" href="/"{% if page.url == "/" %} aria-current="page"{% endif %}>Home</a>
        </li>
        <li><a class="pill" href="/work/"{% if page.url == "/work/" or project %} aria-current="page"{% endif %}>Work</a></li>
        <li><a class="pill" href="/studio/"{% if page.url == "/studio/" %} aria-current="page"{% endif %}>Studio</a></li>
        <li><a class="pill" href="/contact/"{% if page.url == "/contact/" %} aria-current="page"{% endif %}>Contact</a></li>
    </ul>
</nav>
